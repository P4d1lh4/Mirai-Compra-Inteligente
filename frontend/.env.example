# Frontend Environment Variables
# Copie este arquivo para .env.local e configure com seus valores

# ======================================
# API Configuration
# ======================================

# URL da API (usado pelo frontend)
# Local: /api/v1 (proxy através de next.config.js)
# Produção: https://seu-backend.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# ======================================
# Analytics (Opcional)
# ======================================

# Google Analytics ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://...

# ======================================
# Feature Flags (Opcional)
# ======================================

# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# ======================================
# Vercel Specific
# ======================================

# Não precisa configurar - Vercel define automaticamente
# VERCEL_ENV (development | preview | production)
# VERCEL_URL (seu-projeto.vercel.app)

