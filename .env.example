# ========================================
# SmartCart Environment Configuration
# ========================================
# Copy this file to .env and update with your values

# ── Application ──
SMARTCART_ENV=development
DEBUG=true

# ── Database ──
# Development (SQLite): sqlite+aiosqlite:///./smartcart.db
# Production (PostgreSQL): postgresql+asyncpg://user:password@localhost:5432/smartcart
DATABASE_URL=sqlite+aiosqlite:///./smartcart.db
DATABASE_URL_SYNC=sqlite:///./smartcart.db

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Authentication (JWT) ──
# IMPORTANT: Change SECRET_KEY to a strong random value in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ── External APIs ──
# Google Maps API Key (for address geocoding)
GOOGLE_MAPS_API_KEY=

# SerpAPI Key (for Google Shopping integration)
SERPAPI_KEY=

# Groq API Key (for AI assistant - free tier)
GROQ_API_KEY=

# ── Frontend ──
# CORS allowed origin for frontend
FRONTEND_URL=http://localhost:3000

# ── Pagination ──
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
